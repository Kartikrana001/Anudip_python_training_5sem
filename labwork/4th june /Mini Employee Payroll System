name = input("Enter Employee Name: ")

salary = input("Enter Basic Salary: ")

try:
    salary = float(salary)

    if salary <= 0:
        print("Invalid Salary!")
    else:
        hra = salary * 0.20
        da = salary * 0.10
        pf = salary * 0.12

        gross = salary + hra + da
        net = gross - pf

        if net > 50000:
            grade = "Senior Grade"
        elif net > 30000:
            grade = "Mid Grade"
        else:
            grade = "Junior Grade"

        print("Employee Name:", name)
        print("Gross Salary:", gross)
        print("Net Salary:", net)
        print("Grade:", grade)

except ValueError:
    print("Invalid Salary Input!")
